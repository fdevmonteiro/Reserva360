# Copie este arquivo para application.properties e preencha com suas credenciais locais
# NUNCA commite o application.properties com valores reais

spring.datasource.url=jdbc:mysql://HOST:3306/reserva_sala?useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=SEU_USUARIO
spring.datasource.password=SUA_SENHA
spring.jpa.database-platform=org.hibernate.dialect.MySQLDialect
spring.jpa.hibernate.ddl-auto=update

spring.mail.host=smtp.office365.com
spring.mail.port=587
spring.mail.username=SEU_EMAIL
spring.mail.password=SUA_SENHA_EMAIL
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.auth=true

spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

jwt.secret=CHAVE_SECRETA_LONGA_E_ALEATORIA_MINIMO_256_BITS

spring.ldap.urls=ldap://SEU_DC:389
spring.ldap.base=DC=dominio,DC=com,DC=br
spring.ldap.username=CN=service-account,OU=ServiceUsers,DC=dominio,DC=com,DC=br
spring.ldap.password=SENHA_SERVICE_ACCOUNT
spring.ldap.base-environment.java.naming.referral=follow

logging.level.org.springframework.security=INFO
logging.level.org.springframework.web=INFO

zoom.api.account-id=SEU_ACCOUNT_ID
zoom.api.client-id=SEU_CLIENT_ID
zoom.api.client-secret=SEU_CLIENT_SECRET
zoom.meeting.buffer-minutes=30
zoom.webhook.verification-token=

microsoft.graph.tenant-id=SEU_TENANT_ID
microsoft.graph.client-id=SEU_CLIENT_ID
microsoft.graph.client-secret=SEU_CLIENT_SECRET

reports.auto.enabled=true
reports.auto.cutoff-minutes=5
reports.auto.batch-size=20
reports.auto.fixed-delay-ms=300000
reports.auto.initial-delay-ms=60000

app.base-url=http://localhost:8080
app.frontend-url=http://localhost:5173
app.cors.allowed-origins=http://localhost:3000,http://localhost:5173
